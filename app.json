{
  "expo": {
    "name": "FlowOS",
    "slug": "flowos",
    "version": "1.0.0",
    "owner": "fel0hegers-team",
    "extra": {
      "eas": {
        "projectId": "aaaae9ae-10b0-4b01-a8dd-0cad92ffbd8f"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.flowos.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE",
        "SYSTEM_ALERT_WINDOW",
        "PACKAGE_USAGE_STATS",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FlowOS needs location to track your runs."
        }
      ],
      [
        "./modules/app-blocker/plugin",
        {}
      ]
    ]
  }
}
